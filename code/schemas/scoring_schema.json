{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DiagBench Scoring Config",
  "description": "Schema for a D1 scoring configuration.",
  "type": "object",
  "additionalProperties": true,
  "required": ["metrics", "oracle_source", "regret_cap", "budget_limit", "attribution_strict_mode"],
  "properties": {
    "metrics": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "enum": ["feasible_rate", "median_regret", "queries_to_feasible", "strict_attribution_rate"]}
    },
    "oracle_source": {"type": "string", "minLength": 1},
    "regret_cap": {"type": "number", "exclusiveMinimum": 0},
    "budget_limit": {"type": "integer", "minimum": 1},
    "attribution_strict_mode": {"type": "boolean"}
  }
}
